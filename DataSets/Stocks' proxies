# 3. Run for all 15 tickers
# ==============================
all_proxies = {}

for ticker in TICKERS:
    print(f"Building proxies for {ticker}...")
    try:
        df_ticker = build_stock_proxy(ticker, weekly_global, SENTIMENT_DIR)
        all_proxies[ticker] = df_ticker

        # Save to CSV (optional; you can later feed this into the forecaster)
        out_path = os.path.join(OUTPUT_DIR, f"{ticker}_proxies.csv")
        df_ticker.to_csv(out_path)
        print(f"  Saved {out_path}")
    except Exception as e:
        print(f"  Failed for {ticker}: {e}")
