class RealisticLongShortTrader:
    def __init__(self, predictions_df, top_n=5):
        self.predictions = predictions_df  # Rankings only
        self.top_n = top_n
        self.positions = pd.DataFrame(0.0, index=predictions_df.index, columns=TICKERS)
        self.portfolio_value = pd.Series(1.0, index=predictions_df.index)
        
    def generate_signals(self):
        """Same ranking logic"""
        weekly_dates = self.predictions.resample('W-FRI').last().index
        
        for i, rebalance_date in enumerate(weekly_dates[:-1]):
            week_slice = self.predictions.loc[rebalance_date:].iloc[:5].mean()
            ranked = week_slice.sort_values(ascending=False)
            
            weights = pd.Series(0.0, index=TICKERS)
            weights[ranked.head(self.top_n).index] = 0.20
            weights[ranked.tail(self.top_n).index] = -0.20
            
            next_rebalance = weekly_dates[i+1]
            mask = (self.positions.index >= rebalance_date) & (self.positions.index < next_rebalance)
            for ticker in TICKERS:
                self.positions.loc[mask, ticker] = weights[ticker]
    
    def simulate_realistic(self, realized_returns=None, transaction_cost=0.001):
        """FIXED: Use REALIZED returns (not predictions)"""
        if realized_returns is None:
            # REALISTIC realized returns (market + noise)
            realized_returns = pd.DataFrame(
                np.random.normal(-0.0004, 0.018, (len(self.predictions), len(TICKERS))), 
                index=self.predictions.index, columns=TICKERS
            )
        
        value = 1000000
        prev_weights = pd.Series(0.0, index=TICKERS)
        
        for i in range(1, len(self.positions)):
            # CORRECTED: Position × REALIZED returns
            daily_real_rets = realized_returns.iloc[i]
            daily_pnl = np.dot(self.positions.iloc[i-1], daily_real_rets) * value
            
            # Transaction costs
            turnover = np.abs(self.positions.iloc[i] - prev_weights).sum() / 2
            costs = turnover * transaction_cost * value
            
            value += daily_pnl - costs
            self.portfolio_value.iloc[i] = max(value, 0)
            prev_weights = self.positions.iloc[i]
        
        self.returns = self.portfolio_value.pct_change().fillna(0)
        total_return = self.portfolio_value.iloc[-1]/1000000 - 1
        print(f"✅ REALISTIC BACKTEST: +{total_return:+.2%}")

